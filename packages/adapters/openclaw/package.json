{
  "name": "@blackunicorn/bonklm-openclaw",
  "version": "0.1.0",
  "description": "OpenClaw integration for BonkLM",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./middleware": {
      "import": "./dist/middleware.js",
      "types": "./dist/middleware.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "lint": "eslint src",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "openclaw",
    "llm",
    "guardrails",
    "security",
    "middleware"
  ],
  "author": "Black Unicorn <security@blackunicorn.tech>",
  "license": "MIT",
  "dependencies": {
    "@blackunicorn/bonklm": "file:../../core"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "openclaw": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
