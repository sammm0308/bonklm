{
  "name": "@blackunicorn/bonklm-logger",
  "version": "0.2.0",
  "description": "Attack Logger & Awareness Display for BonkLM",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "import": "./dist/types.js",
      "types": "./dist/types.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "lint": "eslint src",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "llm",
    "security",
    "guardrails",
    "attack-logger",
    "security-observability"
  ],
  "author": "Black Unicorn <security@blackunicorn.tech>",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "lru-cache": "^11.2.6"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
