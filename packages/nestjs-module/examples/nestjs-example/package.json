{
  "name": "@blackunicorn/bonklm-nestjs-example",
  "version": "1.0.0",
  "description": "Example NestJS app using @blackunicorn/bonklm-nestjs",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "start:dev": "tsx watch src/main.ts",
    "start:debug": "tsx --inspect-brk src/main.ts"
  },
  "dependencies": {
    "@blackunicorn/bonklm": "workspace:*",
    "@blackunicorn/bonklm-nestjs": "workspace:*",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.0.0",
    "typescript": "^5.3.0"
  }
}
