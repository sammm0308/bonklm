{
  "name": "@blackunicorn/bonklm-mastra",
  "version": "1.1.0",
  "description": "Mastra framework connector for BonkLM",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "mastra",
    "llm",
    "guardrails",
    "security",
    "prompt-injection",
    "jailbreak-detection",
    "content-filtering",
    "agents",
    "workflows"
  ],
  "license": "MIT",
  "dependencies": {
    "@blackunicorn/bonklm": "workspace:*"
  },
  "peerDependencies": {
    "@mastra/core": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "@mastra/core": {
      "optional": false
    }
  },
  "devDependencies": {
    "@mastra/core": "^1.4.0",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
