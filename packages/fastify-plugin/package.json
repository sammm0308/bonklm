{
  "name": "@blackunicorn/bonklm-fastify",
  "version": "1.1.0",
  "description": "Fastify plugin for BonkLM",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "fastify",
    "plugin",
    "llm",
    "guardrails",
    "security",
    "prompt-injection",
    "jailbreak",
    "ai-safety"
  ],
  "author": "Black Unicorn <security@blackunicorn.tech>",
  "license": "MIT",
  "dependencies": {
    "@blackunicorn/bonklm": "workspace:*",
    "@blackunicorn/bonklm-logger": "workspace:*",
    "fastify-plugin": "^4.5.0"
  },
  "peerDependencies": {
    "fastify": "^4.0.0 || ^5.0.0"
  },
  "peerDependenciesMeta": {
    "fastify": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
