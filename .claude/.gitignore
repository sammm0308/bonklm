logs/.anomaly_baseline.json
logs/.jailbreak_session.json
logs/.session_security_state.json
logs/.session_risk.json
.*_state.json
.override_state.json
.rate_limit_state.json
.session_*
validators-node/state/

# Lock files
*.lock
.override.lock

# Telemetry files
logs/*.jsonl

# Token files (if stored here)
.bmad-token
.bmad-key

# Temporary files
*.tmp
