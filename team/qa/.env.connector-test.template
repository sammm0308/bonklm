# LLM-Guardrails Connector Testing Environment
# Copy this file to .env.connector-test and fill in your API keys
# Usage: source team/qa/.env.connector-test

# ============== LLM Providers ==============
# OpenAI API Key (for openai-connector)
export OPENAI_API_KEY="sk-your-openai-key-here"

# Anthropic API Key (for anthropic-connector)
export ANTHROPIC_API_KEY="sk-ant-your-anthropic-key-here"

# ============== Vector Databases ==============
# Pinecone (for pinecone-connector)
export PINECONE_API_KEY="your-pinecone-api-key"
export PINECONE_ENVIRONMENT="production"
export PINECONE_INDEX="test-index"

# ============== HuggingFace ==============
# HuggingFace API Token (for huggingface-connector)
export HUGGINGFACE_API_KEY="hf-your-huggingface-token"

# ============== Vector DB URLs ==============
# Qdrant (for qdrant-connector)
export QDRANT_URL="http://localhost:6333"
export QDRANT_API_KEY=""

# Weaviate (for weaviate-connector)
export WEAVIATE_URL="http://localhost:8080"

# ChromaDB (for chroma-connector)
export CHROMA_HOST="localhost"
export CHROMA_PORT="8000"

# ============== Ollama ==============
# Ollama local server (for ollama-connector)
export OLLAMA_HOST="http://localhost:11434"
export OLLAMA_MODEL="llama2"

# ============== Node Environment ==============
export NODE_ENV="development"
export LOG_LEVEL="debug"

# ============== Test Configuration ==============
# Skip tests that require real API keys
export SKIP_API_TESTS="false"

# Timeout for connection tests (ms)
export CONNECTION_TIMEOUT="10000"
